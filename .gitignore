/data/**/*.tar.gz
/data/**/*.zip

# Python / uv (never share the environment)
__pycache__/
*.py[cod]
.venv/
.uv/
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# OS
.DS_Store

# Local working notes / drafts (kept out of the shared repo)
/IMPLEMENTATION_REVIEW.md
/Final Project_v1.pdf

# Note: results/ (figures, metrics CSVs, model checkpoints) ARE committed so
